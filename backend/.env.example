PORT=4000
MONGODB_URI=mongodb://localhost:27017/vedaai
GROQ_API_KEY=your_groq_api_key_here
FRONTEND_URL=http://localhost:3000

# Upstash Redis — REST (used for caching)
UPSTASH_REDIS_REST_URL=https://your-upstash-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# Upstash Redis — TLS protocol URL (used for BullMQ / ioredis)
# Format: rediss://default:<token>@your-endpoint.upstash.io:6379
UPSTASH_REDIS_URL=rediss://default:your_upstash_rest_token@your-upstash-endpoint.upstash.io:6379
